{
  "name": "lain-theme",
  "displayName": "Lain",
  "description": "Serial Experiments Lain inspired theme for VS Code.",
  "version": "2.0.0",
  "publisher": "Haymawon",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0A0A14",
    "theme": "dark"
  },
  "keywords": [
    "lain",
    "serial experiments lain",
    "dark theme",
    "purple",
    "neon",
    "cyberpunk",
    "ethereal"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Haymawon/lain_theme.git"
  },
  "bugs": {
    "url": "https://github.com/Haymawon/lain_theme/issues"
  },
  "homepage": "https://github.com/Haymawon/lain_theme",
  "license": "MIT",
  "contributes": {
    "themes": [
      {
        "label": "Lain (Dark)",
        "uiTheme": "vs-dark",
        "path": "./themes/lain-dark.json"
      },
      {
        "label": "Lain (Light)",
        "uiTheme": "vs",
        "path": "./themes/lain-light.json"
      },
      {
        "label": "Lain (High Contrast)",
        "uiTheme": "hc-black",
        "path": "./themes/lain-high-contrast.json"
      }
    ]
  },
  "scripts": {
    "build": "node build.js",
    "package": "vsce package",
    "validate": "node validate.js",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}
